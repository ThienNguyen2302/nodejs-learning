<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <h3 class="text-center text-secondary mt-5 mb-3">User Login</h3>
            <form class="border rounded w-100 mb-5 mx-auto px-3 pt-3 bg-light" method="post">
                <div class="form-group">
                    <label for="username">Email</label>
                    <input id="username" value = "{{email}}" name="email" type="email" class="form-control" placeholder="Email">
                </div>
                <div class="form-group">
                    <label for="password">Password</label>
                    <input id="password" value = "{{password}}" name="pass" type="password" class="form-control" placeholder="Password">
                </div>
                <div class="form-group">
                    {{#if error}}
                    <div class="alert alert-danger">{{error}}</div>
                    {{/if}}
                    <button class="btn btn-success px-5">Login</button>
                </div>
            </form>

        </div>
    </div>
</div>
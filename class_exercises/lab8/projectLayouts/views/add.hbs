<div class="container">
    <div class="row justify-content-center">
        <div class="col-xl-5 col-lg-6 col-md-8 border mt-3 pt-3 rounded mx-3">
            <div class="form-group text-small">
                <small><a href="/">Quay lại</a></small>
            </div>
            <h4 class="text-success">Thêm sinh viên mới</h4>
            <form novalidate class="mt-3" method="post">
                <div class="form-group">
                    <label for="name">Họ tên</label>
                    <input value = "{{student.name}}" class="form-control" type="text" placeholder="Nhập tên sinh viên" id="name" name="name">
                </div>
                <div class="form-group">
                    <div class="custom-control custom-radio custom-control-inline">
                        <input type="radio" {{checkedMale student.gender}} class="custom-control-input" id="gender-male" name="gender" value="male">
                        <label class="custom-control-label" for="gender-male">Nam</label>
                    </div>
                    <div class="custom-control custom-radio custom-control-inline">
                        <input type="radio" {{checkedFemale student.gender}} class="custom-control-input" id="gender-female" name="gender" value="female">
                        <label class="custom-control-label" for="gender-female">Nữ</label>
                    </div>
                </div>
                <div class="form-group">
                    <label for="age">Tuổi</label>
                    <input value = "{{student.age}}" class="form-control" type="number" placeholder="Nhập tuổi" min="18" max="100" id="age" name="age">
                </div>
                <div class="form-group">
                    <label for="email">Email</label>
                    <input value = "{{student.email}}" class="form-control" type="text" placeholder="Nhập email" id="email" name="email">
                </div>
                <div class="form-group">
                    <label for="address">Địa chỉ</label>
                    <input value = "{{student.address}}" class="form-control" type="text" placeholder="Nhập địa chỉ sinh viên" id="address" name="address">
                </div>
                <div class="form-group">
                    <label for="class">Lớp</label>
                    <input value = "{{student.class}}" class="form-control" type="text" placeholder="Nhập lớp sinh viên" id="class" name="class">
                </div>
                {{#if flash}}
                    <div class="alert alert-{{flash.type}}">{{flash.message}}</div>
                {{/if}}
                <div class="form-group">
                    <button class="btn btn-success mr-2">Thêm sinh viên</button>
                </div>
            </form>
        </div>
    </div>
</div>
<div class="container">
    <div class="row justify-content-center">
        <div class="col-sm-6 col-md-5 col-lg-4">
            <div class="card" class="w-100">
                <img class="card-img-top" src="https://www.w3schools.com/bootstrap4/{{imageGender student.gender}}"
                    alt="Card image">
                <div class="card-body">
                    <h4 class="card-title text-primary">{{student.name}}</h4>
                    <p class="card-text">Giới tính: <strong>{{VnGender student.gender}}</strong></p>
                    <p class="card-text">Tuổi: <strong>{{student.age}}</strong></p>
                    <p class="card-text">Email: <strong>{{student.email}}</strong></p>
                    <p class="card-text">Địa Chỉ: <strong>{{student.address}}</strong></p>
                    <p class="card-text">Lớp: <strong>{{student.class}}</strong></p>
                    <a href="#" class="btn btn-primary">Liên hệ</a>
                </div>
            </div>
            <p class="mt-3"><a href="/" >Quay lại</a></p>
        </div>
    </div>
</div>